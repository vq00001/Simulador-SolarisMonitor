#cloud-config
autoinstall:
  version: 1

  source:  # on the Ubuntu Server ISO, install with the minimal source
    id: ubuntu-server-minimal

  identity:
    hostname: broker-vm
    username: brokeradmin
    # Generar contraseña con mkpasswd -m sha-512
    password: "password"
  
  # Setup network con DHCP para todas las interfaces de red
  network:
    version: 2
    ethernets:
      all-eth:
        match:
          name: "*"
        dhcp4: true
        dhcp6: true

  refresh-installer:
    update: no

  locale: es_CL.UTF-8
  timezone: America/Santiago

  keyboard:
    layout: latam

  ssh:
    install_server: true
    allow-pw: true
    allow-public-key: true

  apt:
    update: true

  packages:
    - python3-full
    - python3-pip
    - python3-venv
    - avahi-daemon

    # Bloque: sistema base
    - git

    # Broker
    - mosquitto
    - mosquitto-clients

  # ----------------------------------------------------------
  # SECCION: CONFIGURACION FINAL
  # ----------------------------------------------------------
  late-commands: # broker-vm.local -> IP
    - curtin in-target -- systemctl enable avahi-daemon --now

    # ejecutar script de configuracion de mosquitto
    - curtin in-target -- systemctl enable mosquitto 
    - curtin in-target -- systemctl enable ssh --now

    # instalar repositorio de simulador-solarismonitor
    - curtin in-target -- su - brokeradmin -c 'git clone https://github.com/vq00001/Simulador-SolarisMonitor /home/brokeradmin/Simulador-SolarisMonitor'


    # crear archivos de configuracion de mosquitto automaticamente
    # seleccionar --mode manual para configurar manualmente
    - curtin in-target -- python3 /home/brokeradmin/Simulador-SolarisMonitor/config/mosquitto_setup.py --mode automatic

    # cargar configuracion de mosquitto
    - curtin in-target -- systemctl restart mosquitto
    - curtin in-target -- echo "Configuración de mosquitto finalizada"