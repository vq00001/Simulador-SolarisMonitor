#cloud-config
autoinstall:
  version: 1

  source:  # on the Ubuntu Server ISO, install with the minimal source
    id: ubuntu-server-minimal

  identity:
    hostname: broker-vm
    username: brokeradmin
    # Generar contraseña con mkpasswd -m sha-512. 
    # La contraseña es "brokeradmin" y se puede cambiar después de la instalación.
    password: "$6$TNxrzr58RzVi1goJ$D9SlN7rxxDFmiKm0ERbKax2YCf8PJqoOVdrLt/.Mcsw4a1tQ0n1dYc08lD4C5RLhw2EsoHugP/KMqt49ZczXT0"

  refresh-installer:
    update: no

  locale: es_CL.UTF-8 
  timezone: America/Santiago

  keyboard:
    layout: latam

  ssh:
    install_server: true
    allow-pw: true
    allow-public-key: true

  apt:
    update: true
    
  user-data:
    write_files:
      - path: /etc/mosquitto/mosquitto.conf
        permissions: "0644"
        content: |
          persistence true
          persistence_location /var/lib/mosquitto/
          log_dest file /var/log/mosquitto/mosquitto.log
          include_dir /etc/mosquitto/conf.d
          password_file /etc/mosquitto/passwd
          acl_file /etc/mosquitto/acl

      - path: /etc/mosquitto/acl
        permissions: "0644"
        content: |   
          user panel
          # para json
          topic read solar_data_panel/+
          # para datos por separado   
          topic read solar_data_panel/temperature/+
          topic read solar_data_panel/irradiance/+
          topic read solar_data_panel/luminosity/+
          topic read solar_data_panel/power/+
          user actuator
          # + -> id
          topic read actuator/+
          topic write actuator/response/+

          user server
          topic write actuator/+
          topic read solar_data_panel/#


      - path: /etc/mosquitto/conf.d/listener.conf
        permissions: "0644"
        content: ""

      - path: /etc/mosquitto/passwd
        permissions: "0644"
        

      # variables de configuracion de red
      - path: /home/brokeradmin
        permissions: "0755"
        content: |
          RATE=54mbit
          DELAY=50ms
          LOSS=5%
          IFACE=$(ip route | awk '/default/ {print $5}')

          PASSWD_FILE="/etc/mosquitto/passwd"

          users=(
              "server server_password"
              "panel panel_password"
              "visualizer visualizer_password"
          )

          sudo systemctl restart mosquitto

          # crear usuarios y contraseñas para mosquitto
          first=true
          for entry in "${users[@]}"; do
              read -r username password <<< "$entry"

              # crear archivo de contraseñas si no existe
              if $first; then
                  sudo mosquitto_passwd -c -b "$PASSWD_FILE" "$username" "$password"
                  first=false
              else
                  sudo mosquitto_passwd -b "$PASSWD_FILE" "$username" "$password"
              fi
          done
            
          echo "Configuración de Mosquitto finalizada"

          # crear script de configuracion de red
          sudo tc qdisc replace dev "$IFACE" root netem \
              rate "$RATE" \
              delay "$DELAY" \
              loss "$LOSS"
              
          echo "Configuración de red finalizada"

  packages:
    - openssh-server
    - python3-full
    - python3-pip
    - python3-venv
    - avahi-daemon
    - net-tools
    - git
    - mosquitto
    - mosquitto-clients

  late-commands:
    - curtin in-target -- sudo -u brokeradmin git clone https://github.com/vq00001/Simulador-SolarisMonitor /home/brokeradmin/Simulador-SolarisMonitor